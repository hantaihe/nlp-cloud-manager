{
	"name": "base",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev:main": "vite dev",
		"dev:sample": "pnpm --filter sample dev",
		"dev:aws": "pnpm --filter @nlp-cloud-manager/aws dev",
		"dev:azure": "pnpm --filter azure dev",
		"dev": "concurrently -n \"MAIN-FE,SAMP-FE,AWS-FE,AZURE-FE\" -c \"blue,magenta,yellow,cyan\" \"npm:dev:main\" \"npm:dev:sample\" \"npm:dev:aws\" \"npm:dev:azure\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/xterm": "^6.0.0",
		"concurrently": "^9.2.1",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"socket.io-client": "^4.8.1",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"vite": "^7.2.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}